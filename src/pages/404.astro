---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Seite nicht gefunden" description="Diese Seite wurde nicht gefunden.">
  <div class="mx-auto max-w-2xl px-5 py-32 text-center">
    <div class="font-serif text-7xl font-semibold">404</div>
    <h1 class="mt-4 font-serif text-2xl font-semibold">Diese Seite wurde leider nicht gefunden!</h1>
    <p class="mt-3 text-muted-foreground">
      Diese Seite existiert nicht. Falls du denkst, dass das ein Fehler ist, wäre es nett wenn du
      den Webmaster darüber informierst:

      <a href="mailto:falco.hirschenberger@gmail.com" class="justify-center flex items-center gap-2 text-blue-600 hover:text-blue-600">
        <span>✉️</span>
        falco.hirschenberger@gmail.com
      </a>
    </p>
    <div class="mt-6 flex justify-center gap-3">
      <a href="/" class="rounded-md bg-foreground px-4 py-2 text-sm font-medium text-background hover:opacity-90">
        Zurück zur Startseite
      </a>
      <a href="/blog" class="rounded-md border border-border px-4 py-2 text-sm hover:bg-muted">
        Schaue im Archiv
      </a>
    </div>
  </div>
</BaseLayout>
